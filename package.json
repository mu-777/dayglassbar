{
  "name": "dayglassbar",
  "productName": "DayGlassBar",
  "version": "0.1.0",
  "description": "Ambient desktop app that shows the time left in your day as a thin bar quietly draining at the edge of your screen. No numbers, no color changes, no alarms.",
  "type": "module",
  "main": "src/main/index.js",
  "author": "mu-777",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "icons": "node tools/gen-icons.mjs",
    "capture": "electron tools/capture-bar.mjs",
    "og": "electron tools/gen-og.mjs",
    "dmg-bg": "electron tools/gen-dmg-background.mjs",
    "version": "node tools/stamp-changelog.mjs && git add CHANGELOG.md",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.mu777.dayglassbar",
    "productName": "DayGlassBar",
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/*.png",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.utilities",
      "icon": "assets/icon.png"
    },
    "dmg": {
      "background": "assets/dmg/background.png",
      "window": { "width": 540, "height": 380 },
      "iconSize": 100,
      "contents": [
        { "x": 130, "y": 150, "type": "file" },
        { "x": 410, "y": 150, "type": "link", "path": "/Applications" }
      ]
    },
    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": true
    }
  }
}
